-- 🚀 ระบบเดิม
local function AutoLockLoop()
    while AutoLockActive do
        pcall(function() LockEvent:FireServer() end)
        task.wait(LOCK_INTERVAL)
    end
end
local function AutoUpgradeLoop()
    while AutoUpgradeActive do
        pcall(function() UpgradeEvent:FireServer("TIER") end)
        task.wait(2)
    end
end
local function AutoShootLoop()
    while AutoShootActive do
        pcall(function() LaunchConf:FireServer(TARGET_POS) end)
        task.wait(3)
    end
end

