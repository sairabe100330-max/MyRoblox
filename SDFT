-- วิ่งเร็ว
local function ToggleSpeed()
    SpeedActive = not SpeedActive
    SpeedBtn.Text = SpeedActive and "🏃‍♂️ ปิด วิ่งเร็ว" or "🏃‍♂️ เปิด วิ่งเร็ว"
    SpeedBtn.BackgroundColor3 = SpeedActive and Color3.fromRGB(255,50,50) or Color3.fromRGB(0,255,0)
    local Char = LocalPlayer.Character
    if Char and Char:FindFirstChild("Humanoid") then
        Char.Humanoid.WalkSpeed = SpeedActive and 50 or 16
    end
end

-- เดินทะลุ
RunService.Stepped:Connect(function()
    if NoclipActive then
        local Char = LocalPlayer.Character
        if Char and Char:FindFirstChild("Humanoid") then
            for _,v in next,Char:GetChildren() do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end
end)
local function ToggleNoclip()
    NoclipActive = not NoclipActive
    NoclipBtn.Text = NoclipActive and "🧱 ปิด เดินทะลุ" or "🧱 เปิด เดินทะลุ"
    NoclipBtn.BackgroundColor3 = NoclipActive and Color3.fromRGB(255,50,50) or Color3.fromRGB(0,255,0)
end

-- ออร่า
local function UpdateAura()
    while AuraActive do
        local Char = LocalPlayer.Character
        if Char and Char:FindFirstChild("HumanoidRootPart") then
            local Root = Char.HumanoidRootPart
            for _,v in next,AuraParts do v:Destroy() end
            AuraParts = {}
            for i=1,6 do
                local Orbit = Instance.new("Part")
                Orbit.Shape = Enum.PartType.Ball
                Orbit.Size = Vector3.new(1,1,1)
                Orbit.Transparency = 0.3
                Orbit.Color = Color3.fromRGB(0,255,255)
                Orbit.Material = Enum.Material.Neon
                Orbit.CanCollide = false
                Orbit.Anchored = true
                Orbit.Parent = workspace
                table.insert(AuraParts, Orbit)
            end
        end
        task.wait(0.1)
    end
    for _,v in next,AuraParts do v:Destroy() end
    AuraParts = {}
end
local function ToggleAura()
    AuraActive = not AuraActive
    AuraBtn.Text = AuraActive and "✨ ปิด ออร่า" or "✨ เปิด ออร่า"
    AuraBtn.BackgroundColor3 = AuraActive and Color3.fromRGB(255,50,50) or Color3.fromRGB(0,255,0)
    if AuraActive then task.spawn(UpdateAura) end
end

