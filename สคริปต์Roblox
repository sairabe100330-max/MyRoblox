-- 🎯 ระบบทำงาน
local function RefreshChar()
    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    Humanoid = Character:WaitForChild("Humanoid", 10)
    Original.Speed = Humanoid.WalkSpeed
    Original.Jump = Humanoid.JumpPower
end
RefreshChar()
LocalPlayer.CharacterAdded:Connect(RefreshChar)

-- กดเปิด/ปิด
SpeedBtn.MouseButton1Click:Connect(function()
    Settings.SpeedEnabled = not Settings.SpeedEnabled
    SpeedBtn.Text = Settings.SpeedEnabled and "✅ ปิดวิ่งเร็ว" or "🔘 เปิดวิ่งเร็ว"
    SpeedBtn.BackgroundColor3 = Settings.SpeedEnabled and Theme.GlowRed or Theme.SideBar
end)

JumpBtn.MouseButton1Click:Connect(function()
    Settings.JumpEnabled = not Settings.JumpEnabled
    JumpBtn.Text = Settings.JumpEnabled and "✅ ปิดกระโดดสูง" or "🔘 เปิดกระโดดสูง"
    JumpBtn.BackgroundColor3 = Settings.JumpEnabled and Theme.GlowRed or Theme.SideBar
end)

-- ลูปอัปเดตค่า
RunService.Heartbeat:Connect(function()
    if not Humanoid or Humanoid.Health <= 0 then return end
    Humanoid.WalkSpeed = Settings.SpeedEnabled and Settings.WalkSpeed or Original.Speed
    Humanoid.JumpPower = Settings.JumpEnabled and Settings.JumpPower or Original.Jump
end)

-- ปุ่มย่อ/ปิด
local Minimized = false
MinBtn.MouseButton1Click:Connect(function()
    Minimized = not Minimized
    TweenService:Create(Main, TweenNorm, {Size = Minimized and UDim2.new(0,580,0,55) or UDim2.new(0,580,0,440)}):Play()
    SideBar.Visible = not Minimized
    Content.Visible = not Minimized
end)

CloseBtn.MouseButton1Click:Connect(function()
    TweenService:Create(Main, TweenNorm, {BackgroundTransparency = 1, Size = UDim2.new(0,0,0,0)}):Play()
    task.wait(0.25)
    if Humanoid then
        Humanoid.WalkSpeed = Original.Speed
        Humanoid.JumpPower = Original.Jump
    end
    env.SunnyHub_Loaded = nil
    SG:Destroy()
end)
